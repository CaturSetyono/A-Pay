---
interface Props {
  title: string;
  description?: string;
  activePath?: string;
}

const { title, description = "Universal Payment & Escrow Skill for Autonomous AI Agents on Pharos", activePath = "/" } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | AgentPay - Pharos Payment Skill</title>
    <meta name="description" content={description} />
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-white text-neutral-900 font-sans antialiased selection:bg-neutral-900 selection:text-white min-h-screen flex flex-col relative">
    <!-- Blueprint Grid Overlay -->
    <div class="absolute inset-0 pointer-events-none -z-10 overflow-hidden">
      <div class="max-w-7xl mx-auto h-full px-6 grid grid-cols-12 gap-0">
        {Array.from({ length: 12 }).map((_, i) => (
          <div class={`h-full border-r border-neutral-50 ${i === 0 ? 'border-l' : ''}`}></div>
        ))}
      </div>
    </div>
    <!-- Header Navigation -->
    <header class="sticky top-0 z-50 w-full border-b border-neutral-200 bg-white/95">
      <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
        <div class="flex items-center gap-6">
          <a href="/" class="flex items-center gap-2">
            <div class="h-6 w-6 bg-neutral-900 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4 text-white">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
              </svg>
            </div>
            <span class="text-base font-bold tracking-tight uppercase">AgentPay</span>
          </a>

          <nav class="hidden md:flex items-center gap-6">
            <a href="/" class={`text-xs font-semibold uppercase tracking-widest transition-opacity hover:opacity-100 ${activePath === '/' ? 'opacity-100 border-b-2 border-neutral-900 pb-1 pt-1' : 'opacity-40'}`}>Home</a>
            <a href="/docs" class={`text-xs font-semibold uppercase tracking-widest transition-opacity hover:opacity-100 ${activePath === '/docs' ? 'opacity-100 border-b-2 border-neutral-900 pb-1 pt-1' : 'opacity-40'}`}>Docs</a>
            <a href="/playground" class={`text-xs font-semibold uppercase tracking-widest transition-opacity hover:opacity-100 ${activePath === '/playground' ? 'opacity-100 border-b-2 border-neutral-900 pb-1 pt-1' : 'opacity-40'}`}>Playground</a>
            <a href="/architecture" class={`text-xs font-semibold uppercase tracking-widest transition-opacity hover:opacity-100 ${activePath === '/architecture' ? 'opacity-100 border-b-2 border-neutral-900 pb-1 pt-1' : 'opacity-40'}`}>Architecture</a>
          </nav>
        </div>

        <div class="flex items-center gap-4">
          <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="hidden sm:inline-flex items-center justify-center px-4 py-2 text-xs font-bold uppercase tracking-wider text-white bg-neutral-900 hover:bg-neutral-800 transition-colors">
            GitHub
          </a>
          <!-- Mobile Menu Button -->
          <button id="mobile-menu-btn" class="md:hidden p-2 text-neutral-400 hover:text-neutral-900" aria-label="Toggle menu">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile navigation -->
      <div id="mobile-menu" class="hidden md:hidden border-b border-neutral-200 bg-white px-6 py-6 space-y-4">
        <a href="/" class={`block text-xs font-bold uppercase tracking-widest ${activePath === '/' ? 'text-neutral-900' : 'text-neutral-400 hover:text-neutral-900'}`}>Home</a>
        <a href="/docs" class={`block text-xs font-bold uppercase tracking-widest ${activePath === '/docs' ? 'text-neutral-900' : 'text-neutral-400 hover:text-neutral-900'}`}>Docs</a>
        <a href="/playground" class={`block text-xs font-bold uppercase tracking-widest ${activePath === '/playground' ? 'text-neutral-900' : 'text-neutral-400 hover:text-neutral-900'}`}>Playground</a>
        <a href="/architecture" class={`block text-xs font-bold uppercase tracking-widest ${activePath === '/architecture' ? 'text-neutral-900' : 'text-neutral-400 hover:text-neutral-900'}`}>Architecture</a>
        <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="block w-full text-center py-3 text-xs font-bold uppercase tracking-wider text-white bg-neutral-900">
          GitHub
        </a>
      </div>
    </header>

    <main class="flex-grow">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-neutral-200 bg-white py-16">
      <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-3 items-start gap-12">
        <div class="flex flex-col gap-4">
          <div class="flex items-center gap-2">
            <div class="h-5 w-5 bg-neutral-900 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3 h-3 text-white">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
              </svg>
            </div>
            <span class="text-xs font-bold uppercase tracking-tight">AgentPay</span>
          </div>
          <p class="text-xs text-neutral-400 leading-relaxed max-w-xs uppercase tracking-wider">
            Building the foundational payment protocol for the autonomous agent economy on Pharos Network.
          </p>
        </div>
        
        <div class="space-y-4">
          <h4 class="text-[10px] font-bold uppercase tracking-[0.2em] text-neutral-400">Navigation</h4>
          <div class="flex flex-col gap-2 text-xs font-semibold uppercase tracking-widest">
            <a href="/docs" class="hover:underline">Documentation</a>
            <a href="/playground" class="hover:underline">Playground</a>
            <a href="/architecture" class="hover:underline">Architecture</a>
          </div>
        </div>

        <div class="space-y-4 md:text-right">
          <h4 class="text-[10px] font-bold uppercase tracking-[0.2em] text-neutral-400">Legal</h4>
          <p class="text-[10px] text-neutral-400 uppercase tracking-widest">© 2026 AgentPay. Pharos Network. MIT License.</p>
        </div>
      </div>
    </footer>

    <!-- Mobile menu toggle script -->
    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      if (btn && menu) {
        btn.addEventListener('click', () => {
          menu.classList.toggle('hidden');
        });
      }
    </script>
  </body>
</html>

<style is:global>
  :root {
    --font-sans: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
    --font-mono: 'JetBrains Mono', monospace;
  }
  
  body {
    font-family: var(--font-sans);
  }

  .font-mono {
    font-family: var(--font-mono);
  }
</style>
