---
interface Props {
  title: string;
  description?: string;
  activePath?: string;
  hideHeaderFooter?: boolean;
}

const { title, description = "Universal Payment & Escrow Skill for Autonomous AI Agents on Pharos", activePath = "/", hideHeaderFooter = false } = Astro.props;
const isHome = activePath === "/";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | AgentPay - Pharos Payment Skill</title>
    <meta name="description" content={description} />
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-neutral-50/50 text-neutral-900 font-sans antialiased selection:bg-neutral-900 selection:text-white min-h-screen flex flex-col relative">
    
    <!-- Splash Screen (Only on Home Page) -->
    {isHome && (
      <div id="splash-screen" class="fixed inset-0 z-[100] bg-neutral-950 flex flex-col items-center justify-center transition-all duration-1000 ease-in-out">
        <img src="/favicon.svg" alt="AgentPay Logo" class="h-32 w-32 mb-8 animate-pulse" />
        <span class="text-white/40 tracking-[0.4em] text-xs font-mono uppercase mb-4">Initializing Protocol</span>
        <div id="splash-counter" class="text-white/80 font-mono text-3xl font-light tracking-widest">0%</div>
      </div>
    )}

    <!-- Blueprint Grid Overlay -->
    <div class="absolute inset-0 pointer-events-none -z-10 overflow-hidden">
      <div class="max-w-7xl mx-auto h-full px-6 grid grid-cols-12 gap-0">
        {Array.from({ length: 12 }).map((_, i) => (
          <div class={`h-full border-r border-neutral-50 ${i === 0 ? 'border-l' : ''}`}></div>
        ))}
      </div>
    </div>
    <!-- Header Navigation -->
    {!hideHeaderFooter && (
      <header id="main-header" class={`fixed top-0 left-0 right-0 z-50 w-full py-3 pointer-events-none transition-all duration-300 ${!isHome ? 'bg-neutral-950 border-b border-neutral-900' : ''}`}>
        <div class="w-full px-8 lg:px-14 h-16 flex items-center justify-between pointer-events-auto">
          <!-- Left: Logo + Brand + Nav -->
          <div class="flex items-center gap-8">
            <!-- Pharos Logo -->
            <a href="./" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 hover:opacity-70 transition-opacity">
              <div class="h-7 w-7 bg-white/10 backdrop-blur-sm flex items-center justify-center rounded-lg border border-white/15">
                <img src="/favicon.svg" alt="AgentPay Logo" class="h-8 w-8 object-contain" />
              </div>
            </a>
            <!-- Brand Name -->
            <a href="/" class="hover:opacity-70 transition-opacity">
              <span class="text-sm font-extrabold tracking-tight uppercase text-white">AgentPay</span>
            </a>
            <!-- Desktop Nav -->
            <nav class="hidden md:flex items-center gap-8 ml-4">
              <a href="/" class={`text-[10px] font-bold uppercase tracking-widest transition-all ${activePath === '/' ? 'text-white' : 'text-white/45 hover:text-white/80'}`}>Home</a>
              <a href="/docs" class={`text-[10px] font-bold uppercase tracking-widest transition-all ${activePath === '/docs' ? 'text-white' : 'text-white/45 hover:text-white/80'}`}>Docs</a>
              <a href="/playground" class={`text-[10px] font-bold uppercase tracking-widest transition-all ${activePath === '/playground' ? 'text-white' : 'text-white/45 hover:text-white/80'}`}>Playground</a>
              <a href="/architecture" class={`text-[10px] font-bold uppercase tracking-widest transition-all ${activePath === '/architecture' ? 'text-white' : 'text-white/45 hover:text-white/80'}`}>Architecture</a>
            </nav>
          </div>

          <!-- Right: CTA + Mobile toggle -->
          <div class="flex items-center gap-4">
            <a href="/playground" class="hidden sm:inline-flex items-center justify-center px-6 py-2.5 text-[11px] font-bold uppercase tracking-widest text-white border border-white/20 bg-white/5 backdrop-blur-sm hover:bg-white/15 hover:border-white/50 transition-all rounded-full shadow-sm">
              Get Started
            </a>
            <!-- Mobile Menu Button -->
            <button id="mobile-menu-btn" class="md:hidden p-2 text-white/60 hover:text-white rounded-lg hover:bg-white/10 transition-colors" aria-label="Toggle menu">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
              </svg>
            </button>
          </div>
        </div>

        <!-- Mobile navigation -->
        <div id="mobile-menu" class="hidden md:hidden border border-white/10 bg-black/80 backdrop-blur-md rounded-2xl p-4 mt-1 space-y-2.5 shadow-lg mx-4 pointer-events-auto">
          <a href="/" class={`block px-3 py-2 text-xs font-bold uppercase tracking-widest rounded-lg ${activePath === '/' ? 'bg-white/15 text-white' : 'text-white/60 hover:bg-white/10 hover:text-white'}`}>Home</a>
          <a href="/docs" class={`block px-3 py-2 text-xs font-bold uppercase tracking-widest rounded-lg ${activePath === '/docs' ? 'bg-white/15 text-white' : 'text-white/60 hover:bg-white/10 hover:text-white'}`}>Docs</a>
          <a href="/playground" class={`block px-3 py-2 text-xs font-bold uppercase tracking-widest rounded-lg ${activePath === '/playground' ? 'bg-white/15 text-white' : 'text-white/60 hover:bg-white/10 hover:text-white'}`}>Playground</a>
          <a href="/architecture" class={`block px-3 py-2 text-xs font-bold uppercase tracking-widest rounded-lg ${activePath === '/architecture' ? 'bg-white/15 text-white' : 'text-white/60 hover:bg-white/10 hover:text-white'}`}>Architecture</a>
          <a href="https://github.com/CaturSetyono/A-Pay.git" target="_blank" rel="noopener noreferrer" class="block w-full text-center py-2.5 text-xs font-bold uppercase tracking-widest text-white border border-white/15 rounded-xl bg-white/[0.08] hover:bg-white/15 transition-colors">
            GitHub Repo
          </a>
        </div>
      </header>
    )}


    <main class="flex-grow">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-neutral-900 bg-neutral-950 text-neutral-400 py-24 relative overflow-hidden">
      <!-- Giant Watermark Background -->
      <div class="absolute inset-x-0 bottom-12 flex justify-center pointer-events-none select-none opacity-[0.03] z-0">
        <span class="font-podium text-[15vw] font-extrabold tracking-tighter uppercase text-white leading-none">AGENTPAY</span>
      </div>

      <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-12 gap-12 lg:gap-16 relative z-10">
        <!-- Columns Grid (Col 1-8) -->
        <div class="md:col-span-8 grid grid-cols-2 sm:grid-cols-4 gap-8">
          <!-- Col 1: Protocol -->
          <div class="space-y-4">
            <h4 class="text-xs font-bold uppercase tracking-widest text-white">Protocol</h4>
            <ul class="space-y-2.5 text-xs">
              <li><a href="/docs#contract-architecture" class="hover:text-white transition-colors">Smart Escrow</a></li>
              <li><a href="/docs#create-escrow" class="hover:text-white transition-colors">Payment Skills</a></li>
              <li><a href="/docs#contract-architecture" class="hover:text-white transition-colors">Auto-Approval</a></li>
              <li><a href="/docs#verify-transaction" class="hover:text-white transition-colors">Verification</a></li>
              <li><a href="/architecture" class="hover:text-white transition-colors">Architecture Spec</a></li>
            </ul>
          </div>

          <!-- Col 2: SDK -->
          <div class="space-y-4">
            <h4 class="text-xs font-bold uppercase tracking-widest text-white">SDK</h4>
            <ul class="space-y-2.5 text-xs">
              <li><a href="/docs#installation" class="hover:text-white transition-colors">Installation</a></li>
              <li><a href="/docs#constructor" class="hover:text-white transition-colors">Client Config</a></li>
              <li><a href="/docs#create-escrow" class="hover:text-white transition-colors">Escrow Lifecycle</a></li>
              <li><a href="https://github.com/CaturSetyono/A-Pay.git" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">TypeScript Core</a></li>
            </ul>
          </div>

          <!-- Col 3: Examples -->
          <div class="space-y-4">
            <h4 class="text-xs font-bold uppercase tracking-widest text-white">Examples</h4>
            <ul class="space-y-2.5 text-xs">
              <li><a href="https://github.com/CaturSetyono/A-Pay.git" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">Research Agent</a></li>
              <li><a href="https://github.com/CaturSetyono/A-Pay.git" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">Marketplace Agent</a></li>
              <li><a href="https://github.com/CaturSetyono/A-Pay.git" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">Trading Agent</a></li>
            </ul>
          </div>

          <!-- Col 4: Resources -->
          <div class="space-y-4">
            <h4 class="text-xs font-bold uppercase tracking-widest text-white">Resources</h4>
            <ul class="space-y-2.5 text-xs">
              <li><a href="/docs" class="hover:text-white transition-colors">Documentation</a></li>
              <li><a href="/playground" class="hover:text-white transition-colors">Launch Playground</a></li>
              <li><a href="https://github.com/CaturSetyono/A-Pay.git" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">GitHub Repo</a></li>
              <li><a href="https://www.pharos.xyz" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">Pharos Network ↗</a></li>
            </ul>
          </div>
        </div>

        <!-- Right Sidebar/CTA (Col 9-12) -->
        <div class="md:col-span-4 flex flex-col md:items-end md:text-right gap-8">
          <!-- Get Started & Description Group -->
          <div class="space-y-4">
            <div>
              <a href="/docs" class="inline-flex items-center justify-center px-8 py-3.5 text-[11px] font-bold uppercase tracking-widest text-white border border-white/20 bg-white/5 backdrop-blur-sm hover:bg-white/15 hover:border-white/50 transition-all rounded-full shadow-sm">
                Get Started
              </a>
            </div>
            <p class="text-xs text-neutral-400 leading-relaxed max-w-sm md:ml-auto">
              AgentPay is the native payment and escrow skill for autonomous AI agents, enabling seamless and trustless value transfer on Pharos Network.
            </p>
          </div>

          <!-- Divider for Right Column on Mobile -->
          <div class="w-12 h-[1px] bg-neutral-900 md:hidden"></div>

          <!-- Socials & Pharos Brand Group -->
          <div class="flex flex-col gap-5 items-start md:items-end w-full">
            <!-- Social Badges (IG, LinkedIn, X) -->
            <div class="flex items-center gap-3">
              <!-- Instagram -->
              <a href="https://www.instagram.com/tyodev.id/" target="_blank" rel="noopener noreferrer" class="h-8 w-8 rounded-full border border-neutral-800 bg-neutral-900 hover:bg-neutral-800 hover:border-neutral-700 transition-colors flex items-center justify-center text-white" aria-label="Instagram">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                  <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/>
                  <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
                  <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
                </svg>
              </a>
              <!-- LinkedIn -->
              <a href="https://www.linkedin.com/in/catursetyono/" target="_blank" rel="noopener noreferrer" class="h-8 w-8 rounded-full border border-neutral-800 bg-neutral-900 hover:bg-neutral-800 hover:border-neutral-700 transition-colors flex items-center justify-center text-white" aria-label="LinkedIn">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                  <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
                  <rect width="4" height="12" x="2" y="9"/>
                  <circle cx="4" cy="4" r="2"/>
                </svg>
              </a>
              <!-- X -->
              <a href="https://x.com/tyodev" target="_blank" rel="noopener noreferrer" class="h-8 w-8 rounded-full border border-neutral-800 bg-neutral-900 hover:bg-neutral-800 hover:border-neutral-700 transition-colors flex items-center justify-center text-white" aria-label="X">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
              </a>
              <!-- GitHub -->
              <a href="https://github.com/CaturSetyono/A-Pay.git" target="_blank" rel="noopener noreferrer" class="h-8 w-8 rounded-full border border-neutral-800 bg-neutral-900 hover:bg-neutral-800 hover:border-neutral-700 transition-colors flex items-center justify-center text-white" aria-label="GitHub">
                <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24" class="w-4 h-4">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Divider -->
      <div class="max-w-7xl mx-auto px-6 my-10 relative z-10">
        <div class="h-[1px] bg-neutral-900"></div>
      </div>

      <!-- Bottom Bar -->
      <div class="max-w-7xl mx-auto px-6 flex flex-col sm:flex-row sm:justify-between items-center gap-4 text-[10px] text-neutral-500 uppercase tracking-widest relative z-10">
        <div class="flex flex-wrap items-center gap-1.5 text-neutral-600 font-medium">
          <span>© 2026 AgentPay. All rights reserved.</span>
        </div>
        <div class="flex items-center gap-3 text-xs">
          <span class="font-bold text-neutral-400">Built on :</span>
          <a href="https://www.pharos.xyz" target="_blank" rel="noopener noreferrer" class="flex items-center hover:opacity-80 transition-opacity">
            <img src="/phaross.png" alt="Pharos Logo" class="h-7 w-auto object-contain drop-shadow-sm" />
          </a>
        </div>
      </div>
    </footer>

    <!-- Script -->
    <script>
      import Lenis from 'lenis';
      
      // Initialize Lenis smooth scrolling (Foolproof RAF loop with ultra-smooth config)
      const lenis = new Lenis({
        duration: 2.0, // Longer duration for heavier glide
        wheelMultiplier: 0.8, // Slightly less distance per wheel tick
        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)), // standard smooth easing
      });

      function raf(time) {
        lenis.raf(time);
        requestAnimationFrame(raf);
      }
      requestAnimationFrame(raf);

      // Handle Splash Screen Fade Out with Loading Counter
      window.addEventListener('load', () => {
        const splash = document.getElementById('splash-screen');
        const counter = document.getElementById('splash-counter');
        if (splash && counter && window.location.pathname === '/') {
          let progress = 0;
          const duration = 1200; // Total duration of loading in ms
          const interval = 30; // update frequency
          const step = 100 / (duration / interval);
          
          const timer = setInterval(() => {
            progress += step;
            if (progress >= 100) {
              progress = 100;
              clearInterval(timer);
              counter.textContent = '100%';
              
              // Fade out immediately when reaching 100%
              setTimeout(() => {
                splash.style.opacity = '0';
                splash.style.pointerEvents = 'none';
                setTimeout(() => {
                  splash.style.display = 'none';
                }, 1000);
              }, 100);
            } else {
              counter.textContent = Math.floor(progress) + '%';
            }
          }, interval);
        }
      });

      // Toggle mobile menu
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      if (btn && menu) {
        btn.addEventListener('click', () => {
          menu.classList.toggle('hidden');
        });
      }

      // Add solid background to header on scroll (only on home page after parallax section)
      window.addEventListener('scroll', () => {
        const header = document.getElementById('main-header');
        if (header && window.location.pathname === '/') {
          // Trigger when the white section is about to hit the navbar (approx 600vh - a little buffer)
          if (window.scrollY > window.innerHeight * 5.9) {
            header.classList.add('bg-neutral-950', 'border-b', 'border-neutral-900');
          } else {
            header.classList.remove('bg-neutral-950', 'border-b', 'border-neutral-900');
          }
        }
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    --font-sans: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
    --font-mono: 'JetBrains Mono', monospace;
  }
  
  body {
    font-family: var(--font-sans);
  }

  .font-mono {
    font-family: var(--font-mono);
  }
</style>
