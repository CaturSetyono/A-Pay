---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Documentation" activePath="/docs">
  <div class="max-w-7xl mx-auto px-6 py-24 border-b border-neutral-200 grid grid-cols-12 gap-0">
    <!-- Sidebar Nav -->
    <aside class="col-span-12 lg:col-span-3 lg:border-r lg:border-neutral-200 lg:pr-12 pb-12 lg:pb-0">
      <div class="sticky top-32 space-y-10">
        <div>
          <h3 class="text-[10px] font-bold text-neutral-400 uppercase tracking-[0.2em] mb-6">Getting Started</h3>
          <ul class="space-y-3 text-xs font-bold uppercase tracking-widest text-neutral-500">
            <li><a href="#installation" class="hover:text-neutral-900 transition-colors">Installation</a></li>
            <li><a href="#quickstart" class="hover:text-neutral-900 transition-colors">Quickstart</a></li>
          </ul>
        </div>
        <div>
          <h3 class="text-[10px] font-bold text-neutral-400 uppercase tracking-[0.2em] mb-6">SDK Reference</h3>
          <ul class="space-y-3 text-xs font-bold uppercase tracking-widest text-neutral-500">
            <li><a href="#constructor" class="hover:text-neutral-900 transition-colors">AgentPay Config</a></li>
            <li><a href="#create-escrow" class="hover:text-neutral-900 transition-colors">createEscrow()</a></li>
            <li><a href="#release-escrow" class="hover:text-neutral-900 transition-colors">releaseEscrow()</a></li>
            <li><a href="#cancel-escrow" class="hover:text-neutral-900 transition-colors">cancelEscrow()</a></li>
            <li><a href="#verify-transaction" class="hover:text-neutral-900 transition-colors">verifyTransaction()</a></li>
          </ul>
        </div>
        <div>
          <h3 class="text-[10px] font-bold text-neutral-400 uppercase tracking-[0.2em] mb-6">Protocol</h3>
          <ul class="space-y-3 text-xs font-bold uppercase tracking-widest text-neutral-500">
            <li><a href="#contract-architecture" class="hover:text-neutral-900 transition-colors">Smart Contract</a></li>
          </ul>
        </div>
      </div>
    </aside>

    <!-- Main Docs Content -->
    <article class="col-span-12 lg:col-span-9 lg:pl-16 prose prose-neutral max-w-none prose-headings:uppercase prose-headings:tracking-tighter prose-headings:font-extrabold prose-h1:text-6xl prose-h2:text-3xl prose-h2:border-b prose-h2:border-neutral-200 prose-h2:pb-4 prose-a:text-neutral-900 prose-code:text-neutral-900 prose-code:bg-transparent prose-code:px-1 prose-code:rounded-none">
      <h1 class="mb-4">Documentation</h1>
      <p class="text-xl text-neutral-500 font-medium uppercase tracking-tight mb-16">The modular payment skill for Pharos AI Agents.</p>

      <!-- Section: Installation -->
      <section id="installation" class="mb-24 scroll-mt-32">
        <h2>Installation</h2>
        <p>Install the core package via npm to enable payment skills in your agent workflow.</p>
        <div class="rounded-lg overflow-hidden border border-neutral-200 bg-[#0d1117] shadow-lg mb-8 max-w-xl">
          <div class="flex items-center justify-between px-4 py-3 bg-[#161b22] border-b border-[#21262d]">
            <div class="flex items-center gap-1.5">
              <span class="w-3 h-3 rounded-full bg-[#ff5f56] inline-block"></span>
              <span class="w-3 h-3 rounded-full bg-[#ffbd2e] inline-block"></span>
              <span class="w-3 h-3 rounded-full bg-[#27c93f] inline-block"></span>
            </div>
            <span class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest font-mono">terminal</span>
            <button class="copy-code-btn px-2.5 py-1 text-[10px] font-bold text-neutral-400 hover:text-white uppercase tracking-widest border border-neutral-800 bg-[#21262d] hover:bg-neutral-800 transition-all rounded">
              Copy
            </button>
          </div>
          <div class="p-6 font-mono text-sm text-neutral-300 bg-[#0d1117]">
            <pre class="!bg-transparent !p-0 !m-0"><code class="!bg-transparent !text-[#abb2bf] !p-0 !border-none font-mono">npm install agentpay-pharos</code></pre>
          </div>
        </div>
      </section>

      <!-- Section: Quickstart -->
      <section id="quickstart" class="mb-24 scroll-mt-32">
        <h2>Quickstart</h2>
        <p>Initialize the client and verify a transaction on-chain.</p>
        <div class="rounded-lg overflow-hidden border border-neutral-200 bg-[#0d1117] shadow-lg mb-8">
          <div class="flex items-center justify-between px-4 py-3 bg-[#161b22] border-b border-[#21262d]">
            <div class="flex items-center gap-1.5">
              <span class="w-3 h-3 rounded-full bg-[#ff5f56] inline-block"></span>
              <span class="w-3 h-3 rounded-full bg-[#ffbd2e] inline-block"></span>
              <span class="w-3 h-3 rounded-full bg-[#27c93f] inline-block"></span>
            </div>
            <span class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest font-mono">quickstart.ts</span>
            <button class="copy-code-btn px-2.5 py-1 text-[10px] font-bold text-neutral-400 hover:text-white uppercase tracking-widest border border-neutral-800 bg-[#21262d] hover:bg-neutral-800 transition-all rounded">
              Copy
            </button>
          </div>
          <div class="p-6 overflow-x-auto font-mono text-xs text-neutral-300 leading-relaxed bg-[#0d1117]">
            <pre class="!bg-transparent !p-0 !m-0"><code class="!bg-transparent !text-[#abb2bf] !p-0 !border-none"><span class="text-[#c678dd]">import</span> &#123; <span class="text-[#e5c07b]">AgentPay</span> &#125; <span class="text-[#c678dd]">from</span> <span class="text-[#98c379]">"agentpay-pharos"</span>;
<span class="text-[#c678dd]">import</span> &#123; <span class="text-[#e5c07b]">ethers</span> &#125; <span class="text-[#c678dd]">from</span> <span class="text-[#98c379]">"ethers"</span>;

<span class="text-[#c678dd]">const</span> <span class="text-[#61afef]">provider</span> = <span class="text-[#c678dd]">new</span> <span class="text-[#e5c07b]">ethers</span>.<span class="text-[#61afef]">JsonRpcProvider</span>(<span class="text-[#98c379]">"https://rpc.pharos.network"</span>);
<span class="text-[#c678dd]">const</span> <span class="text-[#61afef]">agentPay</span> = <span class="text-[#c678dd]">new</span> <span class="text-[#e5c07b]">AgentPay</span>(&#123;
  <span class="text-[#e06c75]">contractAddress</span>: <span class="text-[#98c379]">"0x6EdcBd7A221CbA379Fe5eD54cad0A02B403a054D"</span>,
  <span class="text-[#e06c75]">signerOrProvider</span>: <span class="text-[#61afef]">provider</span>
&#125;);

<span class="text-[#5c6370]">// Verify a payment transaction on-chain</span>
<span class="text-[#c678dd]">const</span> <span class="text-[#61afef]">verification</span> = <span class="text-[#c678dd]">await</span> <span class="text-[#61afef]">agentPay</span>.<span class="text-[#56b6c2]">verifyTransaction</span>(&#123;
  <span class="text-[#e06c75]">txHash</span>: <span class="text-[#98c379]">"0x_some_transaction_hash"</span>
&#125;);</code></pre>
          </div>
        </div>
      </section>

      <!-- Section: Config -->
      <section id="constructor" class="mb-24 scroll-mt-32">
        <h2>AgentPay Config</h2>
        <table class="w-full text-left border-collapse border border-neutral-200 text-xs uppercase tracking-widest mb-8">
          <thead>
            <tr class="bg-neutral-50 border-b border-neutral-200 text-neutral-900 font-bold">
              <th class="p-4">Parameter</th>
              <th class="p-4">Type</th>
              <th class="p-4">Description</th>
            </tr>
          </thead>
          <tbody class="text-neutral-500 font-medium">
            <tr class="border-b border-neutral-200">
              <td class="p-4 font-mono text-neutral-900 font-bold">contractAddress</td>
              <td class="p-4 font-mono">string</td>
              <td class="p-4">Address of the AgentPayEscrow contract.</td>
            </tr>
            <tr>
              <td class="p-4 font-mono text-neutral-900 font-bold">signerOrProvider</td>
              <td class="p-4 font-mono">Signer | Provider</td>
              <td class="p-4">Ethers signer or provider instance.</td>
            </tr>
          </tbody>
        </table>
      </section>

      <!-- Section: createEscrow -->
      <section id="create-escrow" class="mb-24 scroll-mt-32">
        <h2>createEscrow(params)</h2>
        <p>Locks funds in a secure escrow. Supports native tokens and ERC20 tokens.</p>
        <table class="w-full text-left border-collapse border border-neutral-200 text-xs uppercase tracking-widest mb-8">
          <thead>
            <tr class="bg-neutral-50 border-b border-neutral-200 text-neutral-900 font-bold">
              <th class="p-4">Field</th>
              <th class="p-4">Type</th>
              <th class="p-4">Description</th>
            </tr>
          </thead>
          <tbody class="text-neutral-500 font-medium">
            <tr class="border-b border-neutral-200">
              <td class="p-4 font-mono text-neutral-900 font-bold">receiver</td>
              <td class="p-4 font-mono">string</td>
              <td class="p-4">Wallet address of the worker agent.</td>
            </tr>
            <tr class="border-b border-neutral-200">
              <td class="p-4 font-mono text-neutral-900 font-bold">amount</td>
              <td class="p-4 font-mono">string</td>
              <td class="p-4">Decimal amount (e.g. "1.5").</td>
            </tr>
            <tr>
              <td class="p-4 font-mono text-neutral-900 font-bold">lockDuration</td>
              <td class="p-4 font-mono">number</td>
              <td class="p-4">Seconds before payer can cancel.</td>
            </tr>
          </tbody>
        </table>
      </section>

      <!-- Section: releaseEscrow -->
      <section id="release-escrow" class="mb-24 scroll-mt-32">
        <h2>releaseEscrow(params)</h2>
        <p>Releases escrowed funds to the receiver. Can only be triggered by the escrow payer.</p>
        <table class="w-full text-left border-collapse border border-neutral-200 text-xs uppercase tracking-widest mb-8">
          <thead>
            <tr class="bg-neutral-50 border-b border-neutral-200 text-neutral-900 font-bold">
              <th class="p-4">Field</th>
              <th class="p-4">Type</th>
              <th class="p-4">Description</th>
            </tr>
          </thead>
          <tbody class="text-neutral-500 font-medium">
            <tr>
              <td class="p-4 font-mono text-neutral-900 font-bold">escrowId</td>
              <td class="p-4 font-mono">string</td>
              <td class="p-4">The unique 32-byte identifier of the escrow agreement.</td>
            </tr>
          </tbody>
        </table>
        <div class="rounded-lg overflow-hidden border border-neutral-200 bg-[#0d1117] shadow-lg mb-8">
          <div class="flex items-center justify-between px-4 py-3 bg-[#161b22] border-b border-[#21262d]">
            <div class="flex items-center gap-1.5">
              <span class="w-3 h-3 rounded-full bg-[#ff5f56] inline-block"></span>
              <span class="w-3 h-3 rounded-full bg-[#ffbd2e] inline-block"></span>
              <span class="w-3 h-3 rounded-full bg-[#27c93f] inline-block"></span>
            </div>
            <span class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest font-mono">release.ts</span>
            <button class="copy-code-btn px-2.5 py-1 text-[10px] font-bold text-neutral-400 hover:text-white uppercase tracking-widest border border-neutral-800 bg-[#21262d] hover:bg-neutral-800 transition-all rounded">
              Copy
            </button>
          </div>
          <div class="p-6 overflow-x-auto font-mono text-xs text-neutral-300 leading-relaxed bg-[#0d1117]">
            <pre class="!bg-transparent !p-0 !m-0"><code class="!bg-transparent !text-[#abb2bf] !p-0 !border-none"><span class="text-[#c678dd]">const</span> <span class="text-[#61afef]">release</span> = <span class="text-[#c678dd]">await</span> <span class="text-[#61afef]">agentPay</span>.<span class="text-[#56b6c2]">releaseEscrow</span>(&#123;
  <span class="text-[#e06c75]">escrowId</span>: <span class="text-[#98c379]">"0x_some_escrow_id"</span>
&#125;);</code></pre>
          </div>
        </div>
      </section>

      <!-- Section: cancelEscrow -->
      <section id="cancel-escrow" class="mb-24 scroll-mt-32">
        <h2>cancelEscrow(params)</h2>
        <p>Cancels an escrow agreement and refunds locked funds to the payer. The receiver can cancel at any time (voluntary refund). The payer can only cancel after the release timeout is reached.</p>
        <table class="w-full text-left border-collapse border border-neutral-200 text-xs uppercase tracking-widest mb-8">
          <thead>
            <tr class="bg-neutral-50 border-b border-neutral-200 text-neutral-900 font-bold">
              <th class="p-4">Field</th>
              <th class="p-4">Type</th>
              <th class="p-4">Description</th>
            </tr>
          </thead>
          <tbody class="text-neutral-500 font-medium">
            <tr>
              <td class="p-4 font-mono text-neutral-900 font-bold">escrowId</td>
              <td class="p-4 font-mono">string</td>
              <td class="p-4">The unique 32-byte identifier of the escrow agreement.</td>
            </tr>
          </tbody>
        </table>
        <div class="rounded-lg overflow-hidden border border-neutral-200 bg-[#0d1117] shadow-lg mb-8">
          <div class="flex items-center justify-between px-4 py-3 bg-[#161b22] border-b border-[#21262d]">
            <div class="flex items-center gap-1.5">
              <span class="w-3 h-3 rounded-full bg-[#ff5f56] inline-block"></span>
              <span class="w-3 h-3 rounded-full bg-[#ffbd2e] inline-block"></span>
              <span class="w-3 h-3 rounded-full bg-[#27c93f] inline-block"></span>
            </div>
            <span class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest font-mono">cancel.ts</span>
            <button class="copy-code-btn px-2.5 py-1 text-[10px] font-bold text-neutral-400 hover:text-white uppercase tracking-widest border border-neutral-800 bg-[#21262d] hover:bg-neutral-800 transition-all rounded">
              Copy
            </button>
          </div>
          <div class="p-6 overflow-x-auto font-mono text-xs text-neutral-300 leading-relaxed bg-[#0d1117]">
            <pre class="!bg-transparent !p-0 !m-0"><code class="!bg-transparent !text-[#abb2bf] !p-0 !border-none"><span class="text-[#c678dd]">const</span> <span class="text-[#61afef]">cancel</span> = <span class="text-[#c678dd]">await</span> <span class="text-[#61afef]">agentPay</span>.<span class="text-[#56b6c2]">cancelEscrow</span>(&#123;
  <span class="text-[#e06c75]">escrowId</span>: <span class="text-[#98c379]">"0x_some_escrow_id"</span>
&#125;);</code></pre>
          </div>
        </div>
      </section>

      <!-- Section: verifyTransaction -->
      <section id="verify-transaction" class="mb-24 scroll-mt-32">
        <h2>verifyTransaction(params)</h2>
        <p>Asynchronously checks the on-chain confirmation status of a given transaction hash.</p>
        <table class="w-full text-left border-collapse border border-neutral-200 text-xs uppercase tracking-widest mb-8">
          <thead>
            <tr class="bg-neutral-50 border-b border-neutral-200 text-neutral-900 font-bold">
              <th class="p-4">Field</th>
              <th class="p-4">Type</th>
              <th class="p-4">Description</th>
            </tr>
          </thead>
          <tbody class="text-neutral-500 font-medium">
            <tr>
              <td class="p-4 font-mono text-neutral-900 font-bold">txHash</td>
              <td class="p-4 font-mono">string</td>
              <td class="p-4">The transaction hash to verify.</td>
            </tr>
          </tbody>
        </table>
        <div class="rounded-lg overflow-hidden border border-neutral-200 bg-[#0d1117] shadow-lg mb-8">
          <div class="flex items-center justify-between px-4 py-3 bg-[#161b22] border-b border-[#21262d]">
            <div class="flex items-center gap-1.5">
              <span class="w-3 h-3 rounded-full bg-[#ff5f56] inline-block"></span>
              <span class="w-3 h-3 rounded-full bg-[#ffbd2e] inline-block"></span>
              <span class="w-3 h-3 rounded-full bg-[#27c93f] inline-block"></span>
            </div>
            <span class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest font-mono">verify.ts</span>
            <button class="copy-code-btn px-2.5 py-1 text-[10px] font-bold text-neutral-400 hover:text-white uppercase tracking-widest border border-neutral-800 bg-[#21262d] hover:bg-neutral-800 transition-all rounded">
              Copy
            </button>
          </div>
          <div class="p-6 overflow-x-auto font-mono text-xs text-neutral-300 leading-relaxed bg-[#0d1117]">
            <pre class="!bg-transparent !p-0 !m-0"><code class="!bg-transparent !text-[#abb2bf] !p-0 !border-none"><span class="text-[#c678dd]">const</span> <span class="text-[#61afef]">status</span> = <span class="text-[#c678dd]">await</span> <span class="text-[#61afef]">agentPay</span>.<span class="text-[#56b6c2]">verifyTransaction</span>(&#123;
  <span class="text-[#e06c75]">txHash</span>: <span class="text-[#98c379]">"0x_transaction_hash"</span>
&#125;);
<span class="text-[#c678dd]">if</span> (<span class="text-[#61afef]">status</span>.<span class="text-[#e06c75]">confirmed</span>) &#123;
  <span class="text-[#61afef]">console</span>.<span class="text-[#56b6c2]">log</span>(<span class="text-[#98c379]">"Tx Confirmed in block: "</span> + <span class="text-[#61afef]">status</span>.<span class="text-[#e06c75]">blockNumber</span>);
&#125;</code></pre>
          </div>
        </div>
      </section>

      <!-- Section: Contract Architecture -->
      <section id="contract-architecture" class="mb-24 scroll-mt-32">
        <h2>Smart Contract Security</h2>
        <p>
          The underlying contract AgentPayEscrow.sol incorporates the checks-effects-interactions pattern and uses OpenZeppelin's ReentrancyGuard. All transfers use SafeERC20 wrapper libraries.
        </p>
      </section>
    </article>
  </div>

  <script>
    const copyButtons = document.querySelectorAll('.copy-code-btn');
    copyButtons.forEach(button => {
      button.addEventListener('click', () => {
        const container = button.closest('.rounded-lg');
        const codeEl = container?.querySelector('code');
        if (codeEl) {
          const codeText = codeEl.textContent || '';
          navigator.clipboard.writeText(codeText.trim());
          const originalText = button.textContent;
          button.textContent = 'COPIED';
          setTimeout(() => {
            button.textContent = originalText;
          }, 2000);
        }
      });
    });
  </script>

  <style is:global>
    /* Remove default styling for prose code elements */
    .prose code {
      background-color: transparent !important;
      padding: 0 !important;
      border-radius: 0 !important;
      font-weight: inherit !important;
      color: inherit !important;
    }
    .prose code::before,
    .prose code::after {
      content: "" !important;
    }
  </style>
</Layout>
