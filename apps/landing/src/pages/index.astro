---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home" activePath="/">
  <!-- ── SCROLLING WRAPPER FOR PARALLAX ── -->
  <div id="parallax-wrapper" class="relative w-full" style="height: 600vh;">

    <!-- ── FIXED/STICKY HERO ── -->
    <section class="sticky top-0 hero-section w-full relative overflow-hidden h-screen flex flex-col z-0">

    <!-- ── bg.png FULL BLEED background ── -->
    <div class="absolute inset-0 bg-cover bg-center bg-no-repeat" style="background-image: url('/bg.png');"></div>

    <!-- Fine tech grid subtle overlay -->
    <div class="absolute inset-0 pointer-events-none opacity-[0.025] bg-[linear-gradient(to_right,#4fa3ff_1px,transparent_1px),linear-gradient(to_bottom,#4fa3ff_1px,transparent_1px)] bg-[size:40px_40px]"></div>

    <!-- Watermark text behind agent -->
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none select-none z-[1]">
      <span class="font-extrabold uppercase tracking-tighter leading-none text-black/10" style="font-size: clamp(40px, 15vw, 220px); letter-spacing: -0.04em;">AgentPay</span>
    </div>

    <!-- ── VERTICAL LEFT SIDEBAR ── -->
    <div class="absolute left-6 top-1/2 -translate-y-1/2 z-20 hidden lg:flex flex-col items-center gap-5">
      <!-- Vertical line top -->
      <div class="w-px h-16 bg-black/20"></div>
      <!-- Social icons -->
      <a href="https://www.instagram.com/tyodev.id/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="social-icon-btn">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="w-4 h-4">
          <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
        </svg>
      </a>
      <a href="https://x.com/tyodev" target="_blank" rel="noopener noreferrer" aria-label="X / Twitter" class="social-icon-btn">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
        </svg>
      </a>
      <a href="https://www.linkedin.com/in/catursetyono/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="social-icon-btn">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="w-4 h-4">
          <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/>
        </svg>
      </a>
      <a href="https://github.com/CaturSetyono/A-Pay.git" target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="social-icon-btn">
        <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24" class="w-4 h-4">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
      </a>
      <!-- Vertical line bottom -->
      <div class="w-px h-16 bg-black/20"></div>
    </div>

    <!-- ── MAIN HERO CONTENT ── -->
    <!-- Uses absolute positioning like the reference: agent centered, text overlaid left -->
    <div class="relative z-10 w-full min-h-screen flex flex-col">

      <!-- Spacer for navbar -->
      <div class="h-20 shrink-0"></div>

      <!-- Content area: fills remaining height -->
      <div class="flex-1 relative flex items-center sm:items-end pb-0 sm:pb-24">

        <!-- AGENT CHARACTER — absolute center -->
        <div class="absolute inset-0 flex items-center sm:items-end justify-center z-[2] pointer-events-none">

          <!-- AGENT 3D SEQUENCE (14 FRAMES SEQUENTIAL) -->
          <div id="agent-sequence-container" class="relative flex items-center sm:items-end justify-center w-full sm:w-[90%] md:w-[60%] lg:w-[45%] max-w-[600px] will-change-transform" style="height: 100%; transition: transform 0.1s ease-out;">
            {Array.from({ length: 14 }).map((_, i) => (
              <img
                src={`/agent-character/${i + 1}.svg`}
                class={`agent-frame ${i === 0 ? 'relative z-[20]' : 'absolute inset-0'} w-full h-full object-contain object-center sm:object-bottom select-none transition-opacity duration-[150ms] ease-in-out scale-[1.3] sm:scale-100 origin-center sm:origin-bottom`}
                style={`opacity: ${i === 0 ? 1 : 0}; z-index: ${20 - i}; filter: drop-shadow(0 20px 30px rgba(0,0,0,0.15));`}
                draggable="false"
              />
            ))}
          </div>
        </div>

      </div>
    </div>

    </section>

    <!-- ── PARALLAX TEXT CONTENT (Scrolls over the sticky hero) ── -->
    <!-- Content 1: Appears after scrolling 100vh -->
    <div class="absolute w-full px-6 lg:px-24 pointer-events-none z-10" style="top: 120vh; perspective: 1000px;">
      <div class="max-w-7xl mx-auto flex flex-col items-start">
        <div class="parallax-card transform will-change-transform opacity-0">
          <div class="inline-flex items-center gap-3 mb-6">
            <span class="flex h-3 w-3 relative">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-neutral-900 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-3 w-3 bg-neutral-900"></span>
            </span>
            <span class="text-[10px] font-bold uppercase tracking-[0.3em] text-neutral-900">01 / The Vision</span>
          </div>
          <h2 class="text-4xl sm:text-6xl md:text-8xl font-black text-neutral-900 tracking-tighter leading-[0.85] mb-6">
            Autonomous<br/>Value.
          </h2>
          <div class="max-w-[280px] sm:max-w-md border-l-2 border-neutral-900 pl-4 sm:pl-6 py-2">
            <p class="text-neutral-700 text-xs sm:text-sm md:text-base font-medium leading-relaxed">
              AgentPay enables AI agents to hold balances, escrow funds, and safely purchase services from one another without human intervention.
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Content 2: Appears after scrolling 200vh -->
    <div class="absolute w-full px-6 lg:px-24 pointer-events-none z-10" style="top: 210vh; perspective: 1000px;">
      <div class="max-w-7xl mx-auto flex flex-col items-end text-right">
        <div class="parallax-card transform will-change-transform opacity-0">
          <div class="inline-flex items-center justify-end gap-3 mb-6 w-full">
            <span class="text-[10px] font-bold uppercase tracking-[0.3em] text-neutral-900">02 / Architecture</span>
            <span class="flex h-3 w-3 relative">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-neutral-900 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-3 w-3 bg-neutral-900"></span>
            </span>
          </div>
          <h2 class="text-4xl sm:text-6xl md:text-8xl font-black text-neutral-900 tracking-tighter leading-[0.85] mb-6">
            Built on<br/>Pharos.
          </h2>
          <div class="max-w-[280px] sm:max-w-md border-r-2 border-neutral-900 pr-4 sm:pr-6 py-2 ml-auto">
            <p class="text-neutral-700 text-xs sm:text-sm md:text-base font-medium leading-relaxed">
              Leveraging the speed and finality of Pharos, our smart escrows auto-approve ERC20 tokens and ensure ~0ms settlement globally.
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Content 3: Appears after scrolling 300vh -->
    <div class="absolute w-full px-6 lg:px-24 pointer-events-none z-10" style="top: 300vh; perspective: 1000px;">
      <div class="max-w-7xl mx-auto flex flex-col items-start">
        <div class="parallax-card transform will-change-transform opacity-0">
          <div class="inline-flex items-center gap-3 mb-6">
            <span class="flex h-3 w-3 relative">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-neutral-900 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-3 w-3 bg-neutral-900"></span>
            </span>
            <span class="text-[10px] font-bold uppercase tracking-[0.3em] text-neutral-900">03 / Integration</span>
          </div>
          <h2 class="text-4xl sm:text-6xl md:text-8xl font-black text-neutral-900 tracking-tighter leading-[0.85] mb-6">
            Universal<br/>SDK.
          </h2>
          <div class="max-w-[280px] sm:max-w-md border-l-2 border-neutral-900 pl-4 sm:pl-6 py-2">
            <p class="text-neutral-700 text-xs sm:text-sm md:text-base font-medium leading-relaxed">
              Integrated in minutes. Our drop-in TypeScript SDK abstracts complex escrow logic into single-line function calls for any AI workflow.
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Content 4: Appears after scrolling 390vh -->
    <div class="absolute w-full px-6 lg:px-24 pointer-events-none z-10" style="top: 390vh; perspective: 1000px;">
      <div class="max-w-7xl mx-auto flex flex-col items-end text-right">
        <div class="parallax-card transform will-change-transform opacity-0">
          <div class="inline-flex items-center justify-end gap-3 mb-6 w-full">
            <span class="text-[10px] font-bold uppercase tracking-[0.3em] text-neutral-900">04 / Security</span>
            <span class="flex h-3 w-3 relative">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-neutral-900 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-3 w-3 bg-neutral-900"></span>
            </span>
          </div>
          <h2 class="text-4xl sm:text-6xl md:text-8xl font-black text-neutral-900 tracking-tighter leading-[0.85] mb-6">
            Trustless<br/>Protocol.
          </h2>
          <div class="max-w-[280px] sm:max-w-md border-r-2 border-neutral-900 pr-4 sm:pr-6 py-2 ml-auto">
            <p class="text-neutral-700 text-xs sm:text-sm md:text-base font-medium leading-relaxed">
              Funds are cryptographically locked on-chain. No intermediaries, no counterparty risk—just pure mathematical certainty for transactions.
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Content 5: Appears after scrolling 480vh -->
    <div class="absolute w-full px-6 lg:px-24 pointer-events-none z-10" style="top: 480vh; perspective: 1000px;">
      <div class="max-w-7xl mx-auto flex flex-col items-start">
        <div class="parallax-card transform will-change-transform opacity-0">
          <div class="inline-flex items-center gap-3 mb-6">
            <span class="flex h-3 w-3 relative">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-neutral-900 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-3 w-3 bg-neutral-900"></span>
            </span>
            <span class="text-[10px] font-bold uppercase tracking-[0.3em] text-neutral-900">05 / Use Cases</span>
          </div>
          <h2 class="text-4xl sm:text-6xl md:text-8xl font-black text-neutral-900 tracking-tighter leading-[0.85] mb-6">
            Beyond<br/>Payments.
          </h2>
          <div class="max-w-[280px] sm:max-w-md border-l-2 border-neutral-900 pl-4 sm:pl-6 py-2">
            <p class="text-neutral-700 text-xs sm:text-sm md:text-base font-medium leading-relaxed">
              From automated supply chain settlements to decentralized AI swarms negotiating compute resources.
            </p>
          </div>
        </div>
      </div>
    </div>

  </div> <!-- End 600vh wrapper -->

  <!-- Problem & Solution Section (Clean Split Layout) -->
  <section class="relative z-20 border-b border-neutral-200 bg-neutral-50 py-24 shadow-[0_-20px_50px_rgba(0,0,0,0.05)]">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-stretch">
        <!-- Challenge Card (Left) -->
        <div class="animasi-pemanis transform translate-y-12 opacity-0 transition-all duration-700 ease-out lg:col-span-6 bg-white border border-neutral-200 rounded-xl p-8 sm:p-12 flex flex-col justify-between hover:shadow-sm">
          <div class="space-y-6">
            <div class="inline-flex items-center gap-2 text-[10px] font-bold uppercase tracking-[0.2em] text-rose-500">
              <div class="h-2 w-2 rounded-full bg-rose-500"></div>
              01 / The Challenge
            </div>
            <h3 class="text-3xl sm:text-4xl font-extrabold text-neutral-900 uppercase tracking-tighter leading-none">
              Agents cannot exchange value safely.
            </h3>
            <p class="text-sm text-neutral-500 leading-relaxed">
              Autonomous AI agents are blocked from purchasing API calls, computing power, or data services from one another due to a lack of secure payment rails.
            </p>
          </div>
          <div class="pt-8 border-t border-neutral-200 mt-8 space-y-3 text-xs font-bold text-neutral-500 uppercase tracking-widest">
            <div class="flex items-center gap-3">
              <span class="w-1.5 h-1.5 rounded-full bg-rose-400"></span>
              Direct transfers lack completion guarantees
            </div>
            <div class="flex items-center gap-3">
              <span class="w-1.5 h-1.5 rounded-full bg-rose-400"></span>
              Fragmented custom integrations
            </div>
          </div>
        </div>

        <!-- Solution Card (Right) -->
        <div class="animasi-pemanis transform translate-y-12 opacity-0 transition-all duration-700 ease-out delay-100 lg:col-span-6 bg-neutral-950 border border-neutral-900 text-white rounded-xl p-8 sm:p-12 flex flex-col justify-between hover:shadow-lg relative overflow-hidden">
          <div class="absolute inset-0 pointer-events-none opacity-[0.02] bg-[linear-gradient(to_right,#808080_1px,transparent_1px),linear-gradient(to_bottom,#808080_1px,transparent_1px)] bg-[size:12px_12px]"></div>
          
          <div class="space-y-6 relative z-10">
            <div class="inline-flex items-center gap-2 text-[10px] font-bold uppercase tracking-[0.2em] text-emerald-400">
              <div class="h-2 w-2 rounded-full bg-emerald-400"></div>
              02 / The Protocol
            </div>
            <h3 class="text-3xl sm:text-4xl font-extrabold text-white uppercase tracking-tighter leading-none">
              Unified Escrow standard.
            </h3>
            <p class="text-sm text-neutral-400 leading-relaxed">
              AgentPay provides a standardized protocol for locking, verifying, and releasing funds on-chain based on task execution rules.
            </p>
          </div>
          <div class="pt-8 border-t border-neutral-800 mt-8 space-y-3 text-xs font-bold text-neutral-300 uppercase tracking-widest relative z-10">
            <div class="flex items-center gap-3">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span>
              Trustless value exchange
            </div>
            <div class="flex items-center gap-3">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span>
              Expiration timeout protection
            </div>
            <div class="flex items-center gap-3">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span>
              Simple type-safe Developer SDK
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Modern Features Section (Grid) -->
  <section class="py-24 border-b border-neutral-200 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="animasi-pemanis transform translate-y-8 opacity-0 transition-all duration-700 ease-out text-center mb-16 space-y-4">
        <h2 class="text-xs font-bold uppercase tracking-[0.3em] text-neutral-400">Core Engine</h2>
        <h3 class="text-3xl sm:text-4xl font-extrabold text-neutral-900 uppercase tracking-tighter">Protocol Specifications</h3>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <!-- Specification 1 -->
        <div class="animasi-pemanis transform translate-y-12 opacity-0 transition-all duration-700 ease-out delay-0 p-8 border border-neutral-200 bg-white rounded-xl flex flex-col justify-between h-64">
          <div class="space-y-4">
            <div class="text-[10px] font-mono text-neutral-400">[ REF_ID: EXEC_PAY ]</div>
            <h4 class="text-lg font-bold text-neutral-900 uppercase tracking-tight">Payment Execution</h4>
            <p class="text-xs text-neutral-500 leading-relaxed">
              Facilitate instant native and ERC20 token transfers between AI agents on Pharos with built-in auto-approvals.
            </p>
          </div>
          <!-- Lightning Icon -->
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6 text-neutral-400">
            <path stroke-linecap="round" stroke-linejoin="round" d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z" />
          </svg>
        </div>

        <!-- Specification 2 -->
        <div class="animasi-pemanis transform translate-y-12 opacity-0 transition-all duration-700 ease-out delay-100 p-8 border border-neutral-200 bg-white rounded-xl flex flex-col justify-between h-64">
          <div class="space-y-4">
            <div class="text-[10px] font-mono text-neutral-400">[ REF_ID: VERIF_ASYNC ]</div>
            <h4 class="text-lg font-bold text-neutral-900 uppercase tracking-tight">Async Verification</h4>
            <p class="text-xs text-neutral-500 leading-relaxed">
              Verify transaction confirmations asynchronously. Agents query receipt proofs in a single SDK execution.
            </p>
          </div>
          <!-- Check Icon -->
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6 text-neutral-400">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
          </svg>
        </div>

        <!-- Specification 3 -->
        <div class="animasi-pemanis transform translate-y-12 opacity-0 transition-all duration-700 ease-out delay-200 p-8 border border-neutral-200 bg-white rounded-xl flex flex-col justify-between h-64">
          <div class="space-y-4">
            <div class="text-[10px] font-mono text-neutral-400">[ REF_ID: SECURE_ESC ]</div>
            <h4 class="text-lg font-bold text-neutral-900 uppercase tracking-tight">Secure Escrow</h4>
            <p class="text-xs text-neutral-500 leading-relaxed">
              Immutable Solidity contracts safely hold balances in escrow until cryptographic execution conditions are met.
            </p>
          </div>
          <!-- Lock Icon -->
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6 text-neutral-400">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" />
          </svg>
        </div>

        <!-- Specification 4 -->
        <div class="animasi-pemanis transform translate-y-12 opacity-0 transition-all duration-700 ease-out delay-300 p-8 border border-neutral-200 bg-white rounded-xl flex flex-col justify-between h-64">
          <div class="space-y-4">
            <div class="text-[10px] font-mono text-neutral-400">[ REF_ID: CANCEL_RT ]</div>
            <h4 class="text-lg font-bold text-neutral-900 uppercase tracking-tight">Auto Cancellations</h4>
            <p class="text-xs text-neutral-500 leading-relaxed">
              Integrated timeout protocols automatically refund the origin agent if a requested service drops or fails to fulfill.
            </p>
          </div>
          <!-- Arrow U-Turn Icon -->
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6 text-neutral-400">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 15 3 9m0 0 6-6M3 9h12a6 6 0 0 1 0 12h-3" />
          </svg>
        </div>
      </div>
    </div>
  </section>

  <!-- Installation Section (Clean Split Layout) -->
  <section class="py-24 border-b border-neutral-200 bg-neutral-50/30">
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      <div class="col-span-12 lg:col-span-5 space-y-6">
        <div class="text-xs font-bold text-neutral-400 uppercase tracking-[0.2em]">03 / Quick Integration</div>
        <h3 class="text-4xl sm:text-5xl font-extrabold text-neutral-900 uppercase tracking-tighter leading-tight">
          Ready to deploy in seconds.
        </h3>
        <p class="text-sm text-neutral-500 leading-relaxed max-w-md">
          Install the public package via npm to equip your autonomous AI agents with native payment escrow capabilities.
        </p>
      </div>
      <div class="col-span-12 lg:col-span-7">
        <!-- Terminal MacBook Frame -->
        <div class="rounded-lg overflow-hidden border border-neutral-200 bg-[#0d1117] shadow-lg max-w-xl mx-auto lg:ml-auto lg:mr-0">
          <div class="flex items-center justify-between px-4 py-3 bg-[#161b22] border-b border-[#21262d]">
            <div class="flex items-center gap-1.5">
              <span class="w-3 h-3 rounded-full bg-[#ff5f56] inline-block"></span>
              <span class="w-3 h-3 rounded-full bg-[#ffbd2e] inline-block"></span>
              <span class="w-3 h-3 rounded-full bg-[#27c93f] inline-block"></span>
            </div>
            <span class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest font-mono">terminal</span>
            <button id="copy-install-btn" class="px-2.5 py-1 text-[10px] font-bold text-neutral-400 hover:text-white uppercase tracking-widest border border-neutral-800 bg-[#21262d] hover:bg-neutral-800 transition-all rounded-md">
              Copy
            </button>
          </div>
          <div class="p-6 font-mono text-sm text-neutral-300 bg-[#0d1117]">
            <pre class="!bg-transparent !p-0 !m-0"><code class="!bg-transparent !text-[#abb2bf] !p-0 !border-none font-mono">npm install agentpay-pharos</code></pre>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Example Usage (Matches docs.astro exactly) -->
  <section class="py-24 border-b border-neutral-200 bg-white">
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-12 gap-12">
      <!-- Left side descriptor -->
