  <!-- 3D Sequence Animation Script (Crossfade & Parallax Cards) -->
  <script>
    const wrapper = document.getElementById('parallax-wrapper');
    const frames = document.querySelectorAll('.agent-frame');
    const parallaxCards = document.querySelectorAll('.parallax-card');
    const totalFrames = 14;
    
    if (wrapper && frames.length === totalFrames) {
      window.addEventListener('scroll', () => {
        const rect = wrapper.getBoundingClientRect();
        const maxScroll = wrapper.scrollHeight - window.innerHeight;
        
        let scrollProgress = -rect.top / maxScroll;
        scrollProgress = Math.max(0, Math.min(1, scrollProgress));
        
        // 1. Agent Sequence Logic (Discrete sequential frames)
        const rawIndex = scrollProgress * (totalFrames - 1);
        const activeIndex = Math.round(rawIndex);
        
        frames.forEach((frame, idx) => {
          const el = frame as HTMLElement;
          el.style.opacity = idx === activeIndex ? '1' : '0';
        });

        // 2. Simple Scroll Reveal (Pemanis via Lenis)
        const pemanisElements = document.querySelectorAll('.animasi-pemanis');
        const windowHeight = window.innerHeight;
        pemanisElements.forEach((el) => {
          const rect = el.getBoundingClientRect();
          if (rect.top < windowHeight * 0.9) {
            el.classList.add('translate-y-0', 'opacity-100');
            el.classList.remove('translate-y-12', 'translate-y-8', 'opacity-0');
          }
        });



        // 3. Cinematic Depth-of-Field Parallax Entrance Animation
        const windowCenter = window.innerHeight / 2;
        let maxCardOpacity = 0;

        parallaxCards.forEach(card => {
          const cardRect = card.getBoundingClientRect();
          const cardCenter = cardRect.top + cardRect.height / 2;
          
          // Distance from the vertical center of the screen
          const distFromCenter = cardCenter - windowCenter;
          const maxDist = window.innerHeight * 0.8; // Extended range for cinematic feel
          
          let normalizedDist = distFromCenter / maxDist;
          normalizedDist = Math.max(-1, Math.min(1, normalizedDist));
          
          // Opacity: non-linear fade for stronger presence at center
          let cardOpacity = 1 - Math.abs(normalizedDist);
          cardOpacity = Math.pow(cardOpacity, 1.5);
          
          // Track max opacity for the agent container effect
          if (cardOpacity > maxCardOpacity) maxCardOpacity = cardOpacity;
          
          // Transform Y: strong vertical parallax
          const translateY = normalizedDist * 150; 
          
          // 3D Tilt: Elements tilt away as they move from center
          const rotateX = normalizedDist * -20; 
          
          // Dynamic Blur: Creates "Camera Focus" effect (Depth of Field)
          const blurAmount = Math.abs(normalizedDist) * 12; // up to 12px blur
          
          // Scale: cinematic push-in
          const scale = 1 - (Math.abs(normalizedDist) * 0.15); 
          
          (card as HTMLElement).style.opacity = cardOpacity.toString();
          (card as HTMLElement).style.filter = `blur(${blurAmount}px)`;
          (card as HTMLElement).style.transform = `translate3d(0, ${translateY}px, 0) scale(${scale}) rotateX(${rotateX}deg)`;
        });

        // 4. Dynamic Agent Container Scaling (Shrink at start, grow at end)
        const agentContainer = document.getElementById('agent-sequence-container');
        if (agentContainer) {
          let targetScale = 1;
          
          if (scrollProgress < 0.1) {
            // Shrink smoothly from 1 to 0.75
            const factor = scrollProgress / 0.1;
            targetScale = 1 - (factor * 0.25);
          } else if (scrollProgress > 0.9) {
            // Grow smoothly from 0.75 to 1
            const factor = (scrollProgress - 0.9) / 0.1;
            targetScale = 0.75 + (factor * 0.25);
          } else {
            // Stay small in the middle while texts scroll by
            targetScale = 0.75;
          }
          
          // Apply scale (smooth CSS transition is already present)
          agentContainer.style.transform = `scale(${targetScale})`;
        }

      }, { passive: true });
    }
  </script>
